# --- raid-helper.xyz (event source) ----------------------------------------
# API token. Required by archive.py.
RAID_HELPER_ACCESS_TOKEN=replace-me
# Discord server id whose calendar to archive. Defaults to Low Pressure.
RAID_HELPER_SERVER_ID=1411835313696804976

# --- Warcraft Logs (enrichment + gap-fill) ---------------------------------
# OAuth client-credentials from https://www.warcraftlogs.com/api/clients/
WCL_CLIENT_ID=replace-me
WCL_CLIENT_SECRET=replace-me
# Optional — defaults to the LP guild id (819778).
WCL_GUILD_ID=819778

# --- Postgres --------------------------------------------------------------
# Railway provides this automatically when Postgres is attached. Override for local dev.
DATABASE_URL=postgres://user:pass@host:5432/dbname

# --- Admin panel -----------------------------------------------------------
# Shared bearer token gating /admin and /api/admin/*. Pick a long random string.
ADMIN_TOKEN=replace-me

# --- Optional tuning (defaults shown) --------------------------------------
# How far before event start to begin archiving (seconds, default 900 = 15 min)
# ARCHIVE_LEAD_TIME_SEC=900
# How long after event start to keep refreshing (seconds, default 86400 = 24h)
# ARCHIVE_REFRESH_WINDOW_SEC=86400
# Per-request delay during raid-helper polling (seconds)
# ARCHIVE_REQUEST_DELAY_SEC=0.5
# Per-request delay during WCL polling (seconds)
# WCL_REQUEST_DELAY_SEC=0.3
# Time window to match a WCL report to a raid-helper event (seconds, default 10800 = 3h)
# WCL_MATCH_WINDOW_SEC=10800
# Re-fetch WCL reports started within this window each cycle (seconds, default 86400)
# WCL_REFRESH_WINDOW_SEC=86400
# How many recent reports to pull from each leader's character feed
# WCL_LEADER_FEED_LIMIT=30
